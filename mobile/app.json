{
  "expo": {
    "name": "BuitenZijn",
    "slug": "buitenzijn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4EB54A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buitenzijn.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4EB54A"
      },
      "package": "com.buitenzijn.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "convexUrl": "https://energetic-kudu-185.convex.cloud",
      "eas": {
        "projectId": "76a642e8-10cb-47cc-88ee-158ca0ca62b5"
      }
    },
    "plugins": ["expo-secure-store", "expo-audio", "expo-asset"]
  }
}
